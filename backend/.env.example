# Trace - Environment Configuration
# Copy this to .env and fill in your API keys

# LLM Provider: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# At least one API key is required for AI-powered answers
# Gemini: https://aistudio.google.com/app/apikey (free tier: 60 req/min)
GEMINI_API_KEY=

# Groq: https://console.groq.com/keys (free tier: 30 req/min)
GROQ_API_KEY=

# Debug mode (true/false)
DEBUG=true

# Comma-separated frontend URLs allowed (CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth - CHANGE THESE IN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=generate-a-random-secret-here-use-openssl-rand-hex-32
